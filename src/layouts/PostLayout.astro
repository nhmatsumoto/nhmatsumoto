---
const { frontmatter } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{frontmatter.title} | nhmatsumoto</title>
  </head>
  <body class="bg-gray-950 text-gray-100">
    <main class="max-w-3xl mx-auto px-6 py-20">
      <nav class="mb-12">
        <a href="/" class="text-primary-500 hover:text-primary-400 transition-colors flex items-center gap-2">
          ← Voltar para a Home
        </a>
      </nav>
      
      <header class="mb-12">
        <time class="text-gray-500 text-sm block mb-4">
          {new Date(frontmatter.pubDate).toLocaleDateString('pt-BR', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <h1 class="text-4xl font-bold mb-6">{frontmatter.title}</h1>
        <div class="flex gap-2">
          {frontmatter.tags?.map(tag => (
            <span class="px-3 py-1 rounded-full text-xs bg-gray-900 border border-gray-800 text-gray-400">
              #{tag}
            </span>
          ))}
        </div>
      </header>

      <article class="prose prose-invert prose-primary max-w-none">
        <slot />
      </article>
    </main>
  </body>
</html>

<style is:global>
  .prose h1 { @apply text-3xl font-bold mt-12 mb-6; }
  .prose h2 { @apply text-2xl font-semibold mt-10 mb-4; }
  .prose h3 { @apply text-xl font-medium mt-8 mb-3; }
  .prose p { @apply text-gray-300 leading-relaxed mb-6; }
  .prose a { @apply text-primary-500 hover:underline; }
  .prose strong { @apply text-white font-semibold; }
  .prose ul { @apply list-disc list-inside mb-6 space-y-2; }
</style>
